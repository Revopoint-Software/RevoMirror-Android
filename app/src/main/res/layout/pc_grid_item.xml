<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="0dp">

    <!-- item内容 -->
    <LinearLayout
        android:id="@+id/layoutItemContent"
        android:layout_width="133dp"
        android:layout_height="128dp"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <com.limelight.view.RoundFrameLayout
            android:layout_width="match_parent"
            android:layout_height="100dp"
            app:rlRadius="8dp">

            <ImageView
                android:id="@+id/imgView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:background="@drawable/bg_item_mirror"
                android:src="@drawable/ic_mirror_offline" />

            <TextView
                android:id="@+id/tvLastFlag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end|bottom"
                android:layout_marginEnd="-0.5dp"
                android:layout_marginBottom="-0.5dp"
                android:background="@drawable/bg_last_flag"
                android:gravity="center"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="@string/Last"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_12" />

            <ProgressBar
                android:id="@+id/prgView"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center"
                android:indeterminate="true"
                android:visibility="gone" />
        </com.limelight.view.RoundFrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_horizontal"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:breakStrategy="simple"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_14" />
        </LinearLayout>
    </LinearLayout>

    <!-- item新建 -->
    <LinearLayout
        android:id="@+id/layoutItemAdd"
        android:layout_width="133dp"
        android:layout_height="128dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:visibility="gone">

        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <ImageView
                android:layout_width="133dp"
                android:layout_height="100dp"
                android:layout_centerHorizontal="true"
                android:background="@drawable/bg_pc_item_add"
                android:scaleType="centerInside"
                android:src="@drawable/ic_mirror_add" />
        </RelativeLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:textColor="@color/white"
            android:textSize="@dimen/sp_14" />
    </LinearLayout>
</RelativeLayout>